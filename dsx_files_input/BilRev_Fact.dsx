     b.BRCLOBC,
    b.BRCLOBT,
    b.BRCLVLM01,
    b.BRCLVLKEYT01,
    b.MTSSUBC,
    b.BRCLVLKEYDSCT01,
    b.BRCLVLM02,
    b.BRCLVLKEYT02,
    b.BRCLVLKEYDSCT02,
    b.BRCLVLM03,
    b.BRCLVLKEYT03,
    b.BRCLVLKEYDSCT03,
    b.BRCLVLM04,
    b.BRCLVLKEYT04,
    b.BRCLVLKEYDSCT04,
    b.BRCLVLM05,
    b.BRCLVLKEYT05,
    b.BRCLVLKEYDSCT05,
    b.BRCLVLM06,
    b.BRCLVLKEYT06,
    b.BRCLVLKEYDSCT06,
    b.BRCORIMCHM,

   
    t.CRPCUSROWIDN,
    t.BAAROWIDN,
    t.BILACTROWIDN,
    t.BILACTIDN,
    t.BILREVTRXA,
    t.BILREVTRXD,
    t.BILREVYRN,
    t.BILREVMONC,
    t.WRHUPDH,

  
    c.CRPCUSACTTYPT
FROM 
    #pTeradataMTS.pSchema#.VMTS_BRC_EDWT b,
    #pTeradataMTS.pSchema#.VMTS_BILREVTRX_EDWT t,
    #pTeradataMTS.pSchema#.VMTS_CRPCUS_EDWT c
WHERE 
    t.CRPCUSROWIDN IS NOT NULL
    AND t.BILREVTRXD >= LAST_DAY((
        SELECT IMPCT_CLMN_VAL_DT
        FROM #pTeradataMTS.pSchema#.VMTS_CONTROL_TABLE
        WHERE JOB_NAME = 'm_BilRev_Fact_Sales'
    )) + 1
    AND t.BILREVTRXD <= LAST_DAY(LAST_DAY((
        SELECT IMPCT_CLMN_VAL_DT
        FROM #pTeradataMTS.pSchema#.VMTS_CONTROL_TABLE
        WHERE JOB_NAME = 'm_BilRev_Fact_Sales'
    )) + 1)
    AND c.CRPCUSACTTYPT = 'Business'
    AND t.BRCK = b.BRCK
    AND t.CRPCUSK = c.CRPCUSK;]]><Tables collapsed='1'></Tables><Parameters collapsed='1'></Parameters><Columns collapsed='1'></Columns></SelectStatement></SQL><Transaction><RecordCount modified='1' type='int'><![CDATA[4800000]]></RecordCount><EndOfWave collapsed='1' type='int'><![CDATA[0]]></EndOfWave></Transaction><Session><IsolationLevel type='int'><![CDATA[1]]></IsolationLevel><ArraySize modified='1' type='int'><![CDATA[1]]></ArraySize><SchemaReconciliation><FailOnSizeMismatch type='bool'><![CDATA[1]]></FailOnSizeMismatch><FailOnTypeMismatch type='bool'><![CDATA[1]]></FailOnTypeMismatch></SchemaReconciliation><PassLobLocator collapsed='1' type='bool'><![CDATA[0]]></PassLobLocator></Session><BeforeAfter collapsed='1' type='bool'><![CDATA[0]]></BeforeAfter><BulkAccess><Sleep type='int'><![CDATA[0]]></Sleep><Tenacity type='int'><![CDATA[0]]></Tenacity></BulkAccess><LimitSettings collapsed='1'><MaxSessions type='int'><![CDATA[0]]></MaxSessions><MaxPartitionSessions type='int'><![CDATA[0]]></MaxPartitionSessions><MinSessions type='int'><![CDATA[0]]></MinSessions><MaxBufferSize modified='1' type='int'><![CDATA[#pTeradataMTS.MaxBufferSize#]]></MaxBufferSize><ProgressInterval type='int'><![CDATA[100000]]></ProgressInterval></LimitSettings><ParallelSynchronization collapsed='1' type='bool'><![CDATA[0]]></ParallelSynchronization><LimitRows collapsed='1' modified='1' type='bool'><![CDATA[0]]></LimitRows></Usage></Properties >
=+=+=+=
