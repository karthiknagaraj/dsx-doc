    B.CRPCUSROWIDN, 
    B.BAAROWIDN, 
    B.BILACTROWIDN AS BILACTROWIDN, 
    B.BILREVTRXA, 
    B.BILREVTRXD, 
    B.BILREVYRN, 
    B.BILREVMONC, 
    R.MTSSUBC, 
    R.BRCORIMCHM, 
    R.BRCLVLKEYT01, 
    R.BRCLVLKEYDSCT01, 
    R.BRCLVLKEYT02, 
    R.BRCLVLKEYDSCT02, 
    R.BRCLVLKEYT03, 
    R.BRCLVLKEYDSCT03, 
    R.BRCLVLKEYT04, 
    R.BRCLVLKEYDSCT04, 
    R.BRCLVLKEYT05, 
    R.BRCLVLKEYDSCT05, 
    R.BRCLVLKEYT06, 
    R.BRCLVLKEYDSCT06, 
    B.LOB
FROM #pTeradataMTS.pSchema#.VMTS_BILREVTRX_EDWT B
JOIN #pTeradataMTS.pSchema#.VMTS_BRC_EDWT R
  ON B.BRCK = R.BRCK
JOIN #pTeradataMTS.pSchema#.VMTS_CRPCUS_EDWT C
  ON B.CRPCUSK = C.CRPCUSK
WHERE B.CRPCUSROWIDN IS NOT NULL
  AND B.BILACTROWIDN IS NOT NULL
  AND B.BILREVTRXD > (
        SELECT IMPCT_CLMN_VAL_DT
        FROM #pTeradataMTS.pSchema#.VMTS_CONTROL_TABLE
        WHERE JOB_NAME = 'm_BilRev_Fact_NM1'
    )
  AND C.CRPCUSACTTYPT = 'Business'
  AND B.BRCORIMCHM = 'NM1'
  AND (
        B.LOB = 'Multi LOB' 
        OR B.WRHCREPROM = 'm_edw_Billed_Revenue_Discounts_LDB'
      );
]]><Tables collapsed='1'><Table type='string'><![CDATA[#pTeradataMTS.pSchema#.VMTS_BILREVTRX_EDWT]]></Table><Table type='string'><![CDATA[#pTeradataMTS.pSchema#.VMTS_BRC_EDWT]]></Table><Table type='string'><![CDATA[#pTeradataMTS.pSchema#.VMTS_CRPCUS_EDWT]]></Table></Tables><Parameters collapsed='1'></Parameters><Columns collapsed='1'><Column type='string'><![CDATA[LOB,LOB,#pTeradataMTS.pSchema#.VMTS_BILREVTRX_EDWT]]></Column><Column type='string'><![CDATA[BRCLVLKEYDSCT06,BRCLVLKEYDSCT06,#pTeradataMTS.pSchema#.VMTS_BRC_EDWT]]></Column><Column type='string'><![CDATA[BRCLVLKEYT06,BRCLVLKEYT06,#pTeradataMTS.pSchema#.VMTS_BRC_EDWT]]></Column><Column type='string'><![CDATA[BRCLVLKEYDSCT05,BRCLVLKEYDSCT05,#pTeradataMTS.pSchema#.VMTS_BRC_EDWT]]></Column><Column type='string'><![CDATA[BRCLVLKEYT05,BRCLVLKEYT05,#pTeradataMTS.pSchema#.VMTS_BRC_EDWT]]></Column><Column type='string'><![CDATA[BRCLVLKEYDSCT04,BRCLVLKEYDSCT04,#pTeradataMTS.pSchema#.VMTS_BRC_EDWT]]></Column><Column type='string'><![CDATA[BRCLVLKEYT04,BRCLVLKEYT04,#pTeradataMTS.pSchema#.VMTS_BRC_EDWT]]></Column><Column type='string'><![CDATA[BRCLVLKEYDSCT03,BRCLVLKEYDSCT03,#pTeradataMTS.pSchema#.VMTS_BRC_EDWT]]></Column><Column type='string'><![CDATA[BRCLVLKEYT03,BRCLVLKEYT03,#pTeradataMTS.pSchema#.VMTS_BRC_EDWT]]></Column><Column type='string'><![CDATA[BRCLVLKEYDSCT02,BRCLVLKEYDSCT02,#pTeradataMTS.pSchema#.VMTS_BRC_EDWT]]></Column><Column type='string'><![CDATA[BRCLVLKEYT02,BRCLVLKEYT02,#pTeradataMTS.pSchema#.VMTS_BRC_EDWT]]></Column><Column type='string'><![CDATA[BRCLVLKEYDSCT01,BRCLVLKEYDSCT01,#pTeradataMTS.pSchema#.VMTS_BRC_EDWT]]></Column><Column type='string'><![CDATA[BRCLVLKEYT01,BRCLVLKEYT01,#pTeradataMTS.pSchema#.VMTS_BRC_EDWT]]></Column><Column type='string'><![CDATA[BRCORIMCHM,BRCORIMCHM,#pTeradataMTS.pSchema#.VMTS_BRC_EDWT]]></Column><Column type='string'><![CDATA[MTSSUBC,MTSSUBC,#pTeradataMTS.pSchema#.VMTS_BRC_EDWT]]></Column><Column type='string'><![CDATA[BILREVMONC,BILREVMONC,#pTeradataMTS.pSchema#.VMT