# Example environment variables file
# Copy this to .env and fill in your actual values
# DO NOT commit .env to git!

# Required for semantic search functionality
DSX_API_KEY=your-openrouter-api-key-here

# Optional: Customize the embedding model
DSX_MODEL=openai/text-embedding-3-small

# Optional: Customize the API endpoint
DSX_BASE_URL=https://openrouter.ai/api/v1

# Optional: Specify the provider
DSX_PROVIDER=openrouter

# How to get your API key:
# 1. Go to https://openrouter.ai/
# 2. Sign up for a free account
# 3. Go to Keys section and create a new API key
# 4. Copy the key and paste it above

# Note: Semantic search requires API calls (costs may apply)
# Documentation generation works without any API key
