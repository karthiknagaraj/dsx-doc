// define our input/output link names
inputname 0 Source_Ln;
outputname 0 Source_data_Ln;

initialize {
 // define our control variables
 int8 RowRejected;
 int8 NullSetVar;

}

mainloop {

 // initialise the rejected row variable
 RowRejected = 1;

 // evaluate columns (no constraints) for link: Source_data_Ln
 Source_data_Ln.INSERT_DT_TM = current_timestamp();
 writerecord 0;
 RowRejected = 0;
}

finish {
}

