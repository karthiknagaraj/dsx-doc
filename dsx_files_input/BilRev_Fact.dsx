 // initialise constant values which require conversion
 InterVar0_0 = "Y";
 InterVar0_1 = "99991231 000000";
 InterVar0_2 = "%yyyy%mm%dd%hh%nn%ss";
 InterVar0_3 = "CURRENT ACCOUNT";
 // Stage variable declaration and initialisation
 string StageVar0_svHistoricalLoadFlag;
 StageVar0_svHistoricalLoadFlag = "";
}

mainloop {

 // evaluate the stage variables first
 StageVar0_svHistoricalLoadFlag = HistoricalLoadFlag;

 // initialise the rejected row variable
 RowRejected0 = 1;

 // evaluate columns (no constraints) for link: lnk_tfn_to_join1
 if ((StageVar0_svHistoricalLoadFlag == InterVar0_0)) {
  lnk_tfn_to_join1.Lookup_Date = timestamp_from_ustring(InterVar0_1 , InterVar0_2);
 } else {
  lnk_tfn_to_join1.Lookup_Date = lnk_src_to_txn.BILREVTRXD;
 }
